<?xml version="1.0" encoding="utf-8"?>
<resources>
    <color name="black">#FF000000</color>
    <color name="button_bg">#33FFFFFF</color>
    <color name="button_text">#FFFFFFFF</color>
    <color name="ic_launcher_background">#000000</color>
    <color name="system_time">#CCFFFFFF</color>
    <color name="timer_highlight">#FFFFFFFF</color>
    <color name="white">#FFFFFFFF</color>
    <string name="app_name">专注计时器</string>
    <string name="btn_pause">暂停计时</string>
    <string name="btn_reset">重置计时</string>
    <string name="btn_start">开始计时</string>
    <string name="notification_channel_desc">计时运行中</string>
    <string name="notification_channel_name">专注计时</string>
    <string name="notification_completed">专注 60 分钟已完成</string>
    <string name="notification_text">已计时 %1$s / 60:00</string>
    <string name="notification_title">专注计时运行中</string>
    <style name="Theme.FocusTimer" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryVariant">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/black</item>
    </style>
    <style name="Theme.FocusTimer.Fullscreen" parent="Theme.FocusTimer">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
    <style name="TimerButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/button_text</item>
        <item name="android:textSize">16sp</item>
        <item name="strokeColor">@color/button_bg</item>
        <item name="backgroundTint">@color/button_bg</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minWidth">100dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
    </style>
</resources>